# Variáveis usadas por docker-compose.homologacao.yml (passe com --env-file docker/homolog.env).
# Homologação apenas — troque tudo em produção.

JWT_SECRET=homolog-dev-jwt-change-me
CORS_ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# Devem coincidir com o superusuário criado no assistente do Mayan (http://localhost:8001).
MAYAN_USERNAME=admin
MAYAN_PASSWORD=Admin123!

# ID do tipo de documento no Mayan (lista: GET http://localhost:8001/api/v4/document_types/ com token).
# O assistente costuma criar um tipo padrão; ajuste se o upload na API retornar erro.
MAYAN_DOCUMENT_TYPE_ID=1
