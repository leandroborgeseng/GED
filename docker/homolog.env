# Copiado para `docker/homolog.local.env` e usado com:
# docker compose -f docker-compose.homologacao.yml --env-file docker/homolog.local.env up -d

JWT_SECRET=homolog-dev-jwt-change-me
CORS_ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# Paperless-ngx — alinhar a PAPERLESS_ADMIN_* do compose (criação do superuser na primeira subida).
PAPERLESS_USERNAME=admin
PAPERLESS_PASSWORD=Admin123!
PAPERLESS_ADMIN_MAIL=admin@localhost

# Chave Django do Paperless (homologação); troca em produção.
PAPERLESS_SECRET_KEY=homolog-dev-secret-change-in-prod
