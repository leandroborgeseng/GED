# Variáveis do SERVIÇO "Mayan" na Railway (substitui <...> ou usa Reference Variables).
# Os hostnames <PG_HOST>, <REDIS_HOST>, <RABBIT_HOST> têm de ser os nomes DNS
# PRIVADOS entre serviços (mesmo projeto). Vê em cada serviço → Connect / Networking
# o hostname interno (muitas vezes termina em .railway.internal).
#
# Credenciais abaixo coincidem com docker-compose.homologacao.yml — troca em produção.

MAYAN_DOCKER_WAIT=<PG_HOST>:5432 <RABBIT_HOST>:5672 <REDIS_HOST>:6379

MAYAN_CELERY_BROKER_URL=amqp://mayan:mayanrabbitpass@<RABBIT_HOST>:5672/mayan

MAYAN_CELERY_RESULT_BACKEND=redis://:mayanredispassword@<REDIS_HOST>:6379/1

# Uma única linha (sem quebras). Ajusta PASSWORD ao do teu Postgres Mayan.
MAYAN_DATABASES={'default':{'ENGINE':'django.db.backends.postgresql','NAME':'mayan','PASSWORD':'mayandbpass','USER':'mayan','HOST':'<PG_HOST>','PORT':5432,'CONN_MAX_AGE':0}}

MAYAN_LOCK_MANAGER_BACKEND=mayan.apps.lock_manager.backends.redis_lock.RedisLock

MAYAN_LOCK_MANAGER_BACKEND_ARGUMENTS={'redis_url':'redis://:mayanredispassword@<REDIS_HOST>:6379/2'}
