{
  "name": "ged-platform",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"npm run start:dev -w backend\" \"npm run dev -w frontend\"",
    "build": "npm run build -w backend && npm run build -w frontend",
    "lint": "npm run lint --workspaces --if-present",
    "format": "prettier -w \"**/*.{ts,tsx,js,json,css,md}\"",
    "prepare": "node -e \"const fs=require('fs');if(!fs.existsSync('node_modules/husky'))process.exit(0);require('child_process').execSync('npx husky',{stdio:'inherit'})\""
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,json,css,md}": ["prettier -w"]
  }
}
