# Obrigatório para qualquer comando Prisma (migrate, generate, studio) e para a API em runtime.
# Copie este arquivo para .env na pasta apps/backend: cp .env.example .env
DATABASE_URL=postgresql://ged:ged@localhost:5432/ged?schema=public
JWT_SECRET=troque-em-producao
JWT_ACCESS_SEC=900
CORS_ORIGIN=http://localhost:3000

# Mayan (motor documental) — URL da API REST v4
MAYAN_API_URL=http://localhost:8000/api/v4
MAYAN_USERNAME=admin
MAYAN_PASSWORD=
# ID do tipo de documento no Mayan para upload via gateway (obtenha em /api/v4/document_types/)
MAYAN_DOCUMENT_TYPE_ID=
