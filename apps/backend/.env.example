# Paperless-ngx — URL raiz da instância (ex.: http://localhost:8010 ou https://paperless.seu-dominio.tld)
# A API Nest usa <PAPERLESS_API_URL>/api/…
PAPERLESS_API_URL=http://localhost:8010

# Autenticação na API Paperless: ou token de longa duração (recomendado em produção)…
PAPERLESS_TOKEN=

# …ou utilizador + senha (POST /api/token/)
PAPERLESS_USERNAME=admin
PAPERLESS_PASSWORD=
